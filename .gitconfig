[user]
	name = BeagleXV
	email = fernandooliveira@klever.io
	signingkey = 8886605FB12D706E

[gpg]
    program = /usr/bin/gpg

[core]
    pager = delta
    editor = code --wait
    autocrlf = input

[init]
    defaultBranch = main

[url "ssh://git@github.com/"]
    insteadOf = https://github.com/
    insteadOf = gh:

[commit]
    gpgsign = true

[push]
    autoSetupRemote = true
    default = current
    followTags = true

[pull]
    default = current
    rebase = true

[rebase]
    autoStash = true
    missingCommitsCheck = warn

[diff]
    colorMoved = default

[delta]
    side-by-side = true

[merge]
    conflictstyle = diff3

[interactive]
    diffFilter = delta --color-only
    singlekey = true

[log]
    abbrevCommit = false
    graphColors = red,yellow,cyan,magenta,green,red

[branch]
    sort = -committerdate

[tag]
    sort = -taggerdatee
